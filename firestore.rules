rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function validOptionalString(data, field, maxSize) {
      return !data.keys().hasAny([field]) || (data[field] is string && data[field].size() <= maxSize);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
        data.uid is string &&
        data.email is string &&
        validOptionalString(data, 'displayName', 120) &&
        validOptionalString(data, 'photoURL', 500);
    }

    function isValidTrack(data) {
      return data.keys().hasAll(['id', 'title', 'artist', 'albumArt', 'url', 'duration', 'source', 'userId']) &&
        data.id is string &&
        data.title is string && data.title.size() <= 120 &&
        data.artist is string && data.artist.size() <= 120 &&
        data.albumArt is string &&
        data.url is string &&
        data.duration is number &&
        data.source is string &&
        (data.source == 'community' || data.source == 'studio') &&
        data.userId == request.auth.uid &&
        validOptionalString(data, 'album', 120) &&
        validOptionalString(data, 'genre', 80) &&
        validOptionalString(data, 'mood', 80) &&
        validOptionalString(data, 'lyrics', 5000) &&
        validOptionalString(data, 'description', 500) &&
        validOptionalString(data, 'uploaderName', 120);
    }

    function isValidPlaylist(data) {
      return data.keys().hasAll(['id', 'name', 'coverArt', 'trackIds', 'userId', 'ownerName', 'isPublic', 'followers']) &&
        data.id is string &&
        data.name is string && data.name.size() <= 120 &&
        data.coverArt is string &&
        data.trackIds is list &&
        data.userId == request.auth.uid &&
        data.ownerName is string &&
        data.isPublic is bool &&
        data.followers is number &&
        validOptionalString(data, 'description', 500);
    }

    match /users/{userId} {
      allow read, create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /tracks/{trackId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidTrack(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidTrack(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /playlists/{playlistId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPlaylist(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
